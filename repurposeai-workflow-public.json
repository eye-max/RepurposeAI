    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "linkedinPrompt",
              "name": "linkedinPrompt",
              "value": "=You are a professional content strategist and LinkedIn copywriter.\n\nUsing the article below, write a LinkedIn post that follows these rules:\n- Length: 150 to 300 words\n- Tone: {{ $(\"Set Variables\").item.json.tone }} and insight-driven\n- Open with a compelling hook — a bold statement, surprising fact, or thought-provoking question\n- Highlight 2 to 3 key takeaways relevant to professionals in {{ $(\"Set Variables\").item.json.industry }}\n- Write for this target audience: {{ $(\"Set Variables\").item.json.audience }}\n- Emphasize these key messages if provided: {{ $(\"Set Variables\").item.json.keyMessages }}\n- End with this call to action: {{ $(\"Set Variables\").item.json.cta }}\n- Include 2 to 3 relevant hashtags at the end\n- Do NOT use generic filler phrases like \"In today's world\" or \"In conclusion\"\n- Output only the post text — no labels, no explanations\n\nArticle Title: {{ $(\"Set Variables\").item.json.articleTitle }}\n\nArticle:\n{{ $(\"Set Variables\").item.json.articleText }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "ccb7be2f-617a-47b4-8c32-30af71e69bbe",
      "name": "Build LinkedIn Prompt",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        688,
        32
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Authorization",
              "value": "YOUR_GROQ_API_KEY"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"model\": \"llama-3.3-70b-versatile\", \"max_tokens\": 1024, \"messages\": [{ \"role\": \"user\", \"content\": $(\"Build LinkedIn Prompt\").item.json.linkedinPrompt }] } }}",
        "options": {}
      },
      "id": "9171df4b-ea82-4cfb-a698-3d6796239a51",
      "name": "Groq — LinkedIn",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        912,
